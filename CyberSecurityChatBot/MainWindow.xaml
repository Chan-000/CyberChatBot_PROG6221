<Window x:Class="CyberSecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityChatBot"
        mc:Ignorable="d"
        Title="CyberSecurity ChatBot"
        Height="700" Width="1000"
        Background="#1E1E2F"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header section-->
        <Border Grid.Row="0" 
                Background="#0A2540" 
                CornerRadius="10"
                Padding="10"
                Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal">

                <TextBlock Text=" CYBERSECURITY AWARENESS CHATBOT"
                           FontSize="28"
                           Foreground="white" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="AsciiArtText"
                           FontFamily="Calibri"
                           FontSize="10"
                           FontWeight="ExtraBold"
                           Foreground="Cyan"
                           Margin="15,0,0,0"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>

        <!-- Part 3-->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Chat Area-->
            <Border Grid.Column="0"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,10">

                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto">

                    <TextBlock x:Name="ChatDisplay"
                               Foreground="White"
                               FontSize="16"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <!-- Task assistany Panel-->
            <Border x:Name="TaskPanel"
                    Grid.Column="1"
                    Background="#2D2D44"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,10" >

                <StackPanel>

                    <TextBlock Text="Task Assistant"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Task Title:"
                               Foreground="Cyan"
                               Margin="0,0,0,2"/>

                    <TextBox x:Name="TaskTitleTextBox"                     
                               Height="25"/>

                    <TextBlock Text="Task Description:"
                               Foreground="Cyan"
                               Margin="0,0,0,2"/>

                    <TextBox x:Name="TaskDescriptionTextBox"
                             Height="30"
                             TextWrapping="Wrap"/>

                    <TextBlock Text="Reminder:"
                               Foreground="Cyan"
                               Margin="0,0,0,2"/>
                    
                    <TextBox x:Name="TaskReminderTextBox"
                             Height="24"/>

                    <Button x:Name="AddTaskButton"
                            Content="Add Task"
                            Height="25"
                            Margin="0,0,0,2"
                            Click="AddTaskButton_Click"/>

                    <ListBox x:Name="TaskListBox"
                             Height="162"
                             Margin="0,0,0,2"/>

                    <Button x:Name="CompleteTaskButton"
                            Content="Mark Complete"
                            Height="25"
                            Margin="0,0,0,2"
                            Click="CompleteTaskButton_Click"/>

                    <Button x:Name="DeleteTaskButton"
                            Content="Delete Task"
                            Height="25"
                            Click="DeleteTaskButton_Click"/>
                    
                    <Button x:Name="OpenQuizButton"
                            Content="Start Cybersecurity Quiz"
                            Height="25"
                            Margin="0,4,0,0"
                            Click="OpenQuizButton_Click"/>

                </StackPanel>
            </Border>
            <!--Quiz Panel-->
            <Border  x:Name="QuizPanel"
                     Grid.Column="1"
                     Background="#2D2D44"
                     CornerRadius="10"
                     Padding="10"
                     Margin="0,0,0,10"
                     Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Cybersecurity Quiz"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,5"/>

                    <TextBlock x:Name="ScoreTextBlock"
                               Text="Score: 0"
                               Foreground="Cyan"
                               Margin="0,0,0,5"/>

                    <TextBlock x:Name="QuestionTextBlock"
                               TextWrapping="Wrap"
                               Foreground="White"
                               FontSize="13"
                               Margin="0,0,0,20"/>

                    <Button x:Name="StartQuizButton"
                            Content="Start Quiz"
                            Margin="0,10,0,10"
                            Height="35"
                            Click="StartQuizButton_Click"/>

                    <RadioButton x:Name="OptionA"
                                 GroupName="QuizAnswers"
                                 Foreground="White"
                                 Margin="0,3"/>
                    
                    <RadioButton x:Name="OptionB"
                                 GroupName="QuizAnswers"
                                 Foreground="White"
                                 Margin="0,3"/>

                    <RadioButton x:Name="OptionC"
                                 GroupName="QuizAnswers"
                                 Foreground="White"
                                 Margin="0,3"/>

                    <RadioButton x:Name="OptionD"
                                 GroupName="QuizAnswers"
                                 Foreground="White"
                                 Margin="0,3"/>

                    <Button x:Name="SubmitAnswerButton"
                            Content="Submit Answer"
                            Height="35"
                            Margin="0,10,0,10"
                            Click="SubmitAnswerButton_Click"/>

                    <Button x:Name="NextQuestionButton"
                            Content="Next Question"
                            Height="35"
                            Visibility="Collapsed"
                            Click="NextQuestionButton_Click"/>

                    <TextBlock x:Name="FeedbackTextBlock"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="DarkCyan"
                               FontWeight="Bold"
                               FontFamily="Calibri"
                               Margin="0,10,0,0"/>
                </StackPanel>
                
            </Border>
        </Grid>


        <!-- Input section-->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <!-- User Input -->
            <TextBox x:Name="UserInputTextBox"
                       Grid.Column="0"
                       FontSize="16"
                       Height="60"
                       VerticalAlignment="Center"
                       KeyDown="UserInputTextBox_KeyDown"/>

            <!-- Send Button-->
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    FontSize="24"
                    FontWeight="ExtraBold"
                    Background="Cyan"
                    Foreground="#1E1E2F"
                    Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>
