<Window x:Class="CyberSecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityChatBot"
        mc:Ignorable="d"
        Title="CyberSecurity ChatBot"
        Height="700" Width="1000"
        Background="#1E1E2F"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header section-->
        <Border Grid.Row="0" 
                Background="#0A2540" 
                CornerRadius="10"
                Padding="10"
                Margin="0,0,0,10">
            
            <StackPanel Orientation="Horizontal">
                
                <TextBlock Text=" CYBERSECURITY AWARENESS CHATBOT"
                           FontSize="28"
                           Foreground="white" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="AsciiArtText"
                           FontFamily="Calibri"
                           FontSize="10"
                           FontWeight="ExtraBold"
                           Foreground="Cyan"
                           Margin="15,0,0,0"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                
            </StackPanel>
        </Border>

        <!-- Part 3-->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Chat Area-->
            <Border Grid.Column="0"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,10">

                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto">

                    <TextBlock x:Name="ChatDisplay"
                               Foreground="White"
                               FontSize="16"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
            
            <!-- Task assistany Panel-->
            <Border Grid.Column="1"
                    Background="#2D2D44"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,0,10">

                <StackPanel>

                    <TextBlock Text="Task Assistant"
                               FontSize="19"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <TextBox x:Name="TaskTitleTextBox"
                               Margin="0,0,0,5"                      
                               Height="26"/>

                    <TextBox x:Name="TaskDescriptionTextBox"
                             Margin="0,0,0,5"
                             Height="42"
                             TextWrapping="Wrap"/>

                    <TextBox x:Name="TaskReminderTextBox"
                             Margin="0,0,0,10"
                             Height="27"/>

                    <Button x:Name="AddTaskButton"
                            Content="Add Task"
                            Height="29"
                            Margin="0,0,0,10"
                            Click="AddTaskButton_Click"/>

                    <ListBox x:Name="TaskListBox"
                             Height="190"
                             Margin="0,0,0,10"/>

                    <Button x:Name="CompleteTaskButton"
                            Content="Mark Complete"
                            Height="29"
                            Margin="0,0,0,5"
                            Click="CompleteTaskButton_Click"/>

                    <Button x:Name="DeleteTaskButton"
                            Content="Delete Task"
                            Height="29"
                            Click="DeleteTaskButton_Click"/>

                </StackPanel>
            </Border>
        </Grid>
        

        <!-- Input section-->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            
            <!-- User Input -->
            <TextBox x:Name="UserInputTextBox"
                       Grid.Column="0"
                       FontSize="16"
                       Height="60"
                       VerticalAlignment="Center"
                       KeyDown="UserInputTextBox_KeyDown"/>
            
            <!-- Send Button-->
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    FontSize="24"
                    FontWeight="ExtraBold"
                    Background="Cyan"
                    Foreground="#1E1E2F"
                    Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>
